{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Next.js dev",
            "type": "npm",
            "script": "dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "nextjs",
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\s*(?:✓|Starting).*$",
                    "endsPattern": "^\\s*(?:Ready|Compiled).*$"
                }
            },
            "presentation": {
                "focus": true,
                "panel": "dedicated"
            }
        }
    ]
}